    "item": [
        {
            "name": "Achievements",
            "description": "\nAPI for querying school achievements.",
            "item": [
                {
                    "name": "Get achievements.",
                    "request": {
                        "url": {
                            "host": "{{baseUrl}}",
                            "path": "api\/v1\/units\/:slug\/achievements",
                            "query": [
                                {
                                    "key": "peraih",
                                    "value": "siswa",
                                    "description": "Filter achievements by recipient role: `siswa`, `guru`, `tendik`, or `sekolah`.",
                                    "disabled": false
                                }
                            ],
                            "raw": "{{baseUrl}}\/api\/v1\/units\/:slug\/achievements?peraih=siswa",
                            "variable": [
                                {
                                    "id": "slug",
                                    "key": "slug",
                                    "value": "smk-mandiri",
                                    "description": "The slug of the school unit."
                                }
                            ]
                        },
                        "method": "GET",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application\/json"
                            },
                            {
                                "key": "Accept",
                                "value": "application\/json"
                            }
                        ],
                        "body": null,
                        "description": "Returns a list of achievements for the specified school unit.",
